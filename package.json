{
  "name": "boys-ski-organiser",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun build src/main.jsx --outdir dist --target browser --env 'PUBLIC_*' --watch & bun server.js",
    "build": "bun build src/main.jsx --outdir dist --target browser --env 'PUBLIC_*' --minify",
    "preview": "bun server.js",
    "lint": "bun standard --fix .",
    "format": "bun prettier --write ."
  },
  "dependencies": {
    "appwrite": "^23.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "globals": "^17.4.0",
    "node-appwrite": "^22.1.3",
    "prettier": "3.8.1",
    "standard": "^17.1.2"
  }
}
